{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Lapis Player",
  "mainBinaryName": "Lapis Player",
  "version": "0.1.0",
  "identifier": "com.reon.musicplayer",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Lapis Player",
        "width": 1240,
        "height": 860,
        "minWidth": 980,
        "minHeight": 720
      }
    ],
    "security": {
      "assetProtocol": {
        "enable": true,
        "scope": ["$APPDATA/album-art/**"]
      },
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
